# ============================================================
# NOOGO Backend — Config Production (VPS)
# ============================================================
# 1. Copiez en ".env" sur le serveur et remplissez les valeurs
# 2. NE COMMITTEZ JAMAIS ce fichier avec des vraies valeurs
# 3. Lancez ensuite : php artisan key:generate
# ============================================================

APP_NAME=Noogo
APP_ENV=production
APP_KEY=                    # Généré via php artisan key:generate
APP_DEBUG=false
APP_URL=https://noogo-e5ygx.ondigitalocean.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# ── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error             # Uniquement les erreurs en prod

# ── Base de données MySQL ─────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=noogo_prod
DB_USERNAME=noogo_user
DB_PASSWORD=                # Mot de passe fort

# ── Sessions ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# ── Cache ─────────────────────────────────────────────────────
CACHE_STORE=file            # Ou redis si disponible

# ── Queue ─────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Filesystem ────────────────────────────────────────────────
FILESYSTEM_DISK=public

# ── Cloudflare R2 (S3-compatible, recommandé en prod) ─────────
# Quand CLOUDFLARE_R2_ENDPOINT est défini, l'app utilise le disque "r2"
# pour éviter la perte d'images lors des redeploys.
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=noogo-media
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=

# ── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@noogo.bf
MAIL_FROM_NAME=Noogo

# ── Sanctum (CORS) ───────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=noogo-e5ygx.ondigitalocean.app

# ── Pusher (temps réel commandes) ────────────────────────────
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu
PUSHER_SCHEME=https

# ── CORS ─────────────────────────────────────────────────────
# Autorise l'app Flutter et le dashboard
# Configurer dans config/cors.php si nécessaire
