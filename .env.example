# ===========================================
# NOOGO APP - Configuration Environnement
# ===========================================
# Copiez ce fichier vers .env et remplissez les valeurs

# -------------------------------------------
# API Configuration
# -------------------------------------------
API_BASE_URL=https://dashboard-noogo.quickdev-it.com/api
IMAGE_BASE_URL=https://dashboard-noogo.quickdev-it.com

# -------------------------------------------
# Pusher Configuration (Real-time)
# -------------------------------------------
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=eu

# -------------------------------------------
# Environment
# -------------------------------------------
# Options: development, staging, production
ENVIRONMENT=development

# -------------------------------------------
# Debug
# -------------------------------------------
# Activer les logs verbeux (true/false)
DEBUG_MODE=true
